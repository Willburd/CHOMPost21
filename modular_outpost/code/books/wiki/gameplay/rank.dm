	<li><img class='_rankimage' src=\ref['html/images/outpost/E2.png'] title='[/obj/item/clothing/accessory/rank_eshui/enlisted2::rank]'>: [station_rank_job_list(/obj/item/clothing/accessory/rank_eshui/enlisted2)]</li>
